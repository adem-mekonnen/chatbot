{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand":"sh -c 'uvicorn app.main:app --host 0.0.0.0 --port 8000 & streamlit run app-simple.py --server.port $PORT --server.address 0.0.0.0'",
    "restartPolicyType": "ON_FAILURE",
    "healthcheckPath": "/health"
  }
}