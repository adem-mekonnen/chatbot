# Streamlit Secrets Configuration Example
# Copy this file to secrets.toml and fill in your actual values
# DO NOT commit secrets.toml to git!

JWT_SECRET_KEY = "your-very-long-secret-key-at-least-32-characters-make-it-random-and-secure"
DATABASE_URL = "sqlite+aiosqlite:///./enterprise_state.db"
CHROMA_PERSIST_DIR = "./vectorstore"
CHROMA_COLLECTION = "enterprise_docs"
OLLAMA_URL = "http://localhost:11434"
OLLAMA_MODEL = "llama3.2:latest"

# Get your HuggingFace token from: https://huggingface.co/settings/tokens
HF_INFERENCE_TOKEN = "your-huggingface-token-here"

# Set to true for cloud deployment (uses HuggingFace instead of local Ollama)
USE_HUGGINGFACE_FALLBACK = "true"
